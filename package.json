{
  "name": "netmate",
  "version": "1.0.0",
  "description": "NetMate - 校园网自动登录助手",
  "main": "index.js",
  "scripts": {
    "dev:desktop": "pnpm -C apps/desktop dev",
    "dev:mobile": "concurrently -k -n shared,metro \"pnpm -C packages/shared dev\" \"pnpm -C apps/mobile start\"",
    "android": "pnpm -C apps/mobile android",
    "build:shared": "pnpm -C packages/shared build",
    "build:desktop": "pnpm -C apps/desktop build",
    "build": "pnpm build:shared && pnpm build:desktop",
    "dist": "pnpm -C apps/desktop dist",
    "dist:win": "pnpm -C apps/desktop dist:win",
    "dist:mac": "pnpm -C apps/desktop dist:mac",
    "dist:linux": "pnpm -C apps/desktop dist:linux",
    "dist:android": "pnpm -C apps/mobile build:android",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm -r type-check",
    "test": "pnpm test:shared && pnpm test:desktop && pnpm test:mobile",
    "test:shared": "pnpm -C packages/shared test",
    "test:network": "pnpm -C packages/shared test:network",
    "test:desktop": "pnpm -C apps/desktop test",
    "test:mobile": "pnpm -C apps/mobile test --runInBand",
    "test:e2e": "pnpm -C apps/desktop test:e2e",
    "release:prepare-version": "node ./shell/prepare-release-version.mjs",
    "coverage": "pnpm test:shared -- --coverage && pnpm test:desktop -- --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Twiink/TUST-Campusnet-Login.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Twiink/TUST-Campusnet-Login/issues"
  },
  "homepage": "https://github.com/Twiink/TUST-Campusnet-Login#readme",
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
